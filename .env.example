POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=phishx

# API Settings
API_V1_STR=/api/v1
PROJECT_NAME=PhishX

# Environment (development | production)
PHISHX_ENV=development

# Supabase / Database URL
DATABASE_URL=postgresql://postgres:postgres@db:5432/phishx
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Auth
SECRET_KEY=your-super-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
COOKIE_SECURE=true

# URLs (update for production)
# For Vercel+Render: set FRONTEND_URL to your Vercel URL, BACKEND_URL to your Render URL
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
# Production example:
# FRONTEND_URL=https://phishx-app.vercel.app
# BACKEND_URL=https://phishx-backend.onrender.com

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Stripe
STRIPE_API_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PLAN_ID=price_...
STRIPE_ENTERPRISE_PLAN_ID=price_...

# SendGrid
SENDGRID_API_KEY=SG....

# Sentry
SENTRY_DSN=https://...

# Redis
REDIS_URL=redis://redis:6379/0

# CORS (JSON array of allowed origins — include your Vercel URL in production)
BACKEND_CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]
# Production example:
# BACKEND_CORS_ORIGINS=["https://phishx-app.vercel.app", "http://localhost:5173"]

# Model
EXPECTED_MODEL_HASH=5d1d2d16fabd7ad78a9896cb3dfe5855c622cdccdedcfefe70d47f434c55d899
MODEL_PATH=model/phishing_model.pkl

# Admin Seed (optional — if not set, a random password will be generated)
# ADMIN_EMAIL=admin@phishx.com
# ADMIN_PASSWORD=your-secure-admin-password
